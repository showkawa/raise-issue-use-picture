{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "teams-copilot": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Teams Copilot Proxy",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "apiKey": "unused"
      },
      "models": {
        "claude-sonnet": {
          "name": "Copilot (Claude Sonnet)",
          "tool_call": true,
          "reasoning": false,
          "attachment": false,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "gpt-5-5-chat": {
          "name": "Copilot (GPT-5.5 Chat)",
          "tool_call": true,
          "reasoning": false,
          "attachment": false,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "gpt-5-5-reasoning": {
          "name": "Copilot (GPT-5.5 Reasoning)",
          "tool_call": true,
          "reasoning": false,
          "attachment": false,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "gpt-5-6-reasoning": {
          "name": "Copilot (GPT-5.6 Reasoning)",
          "tool_call": true,
          "reasoning": false,
          "attachment": false,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "claude-sonnet:persist": {
          "name": "Copilot (Claude Sonnet, persist)",
          "tool_call": true,
          "reasoning": false,
          "attachment": false,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "gpt-5-5-chat:persist": {
          "name": "Copilot (GPT-5.5 Chat, persist)",
          "tool_call": true,
          "reasoning": false,
          "attachment": false,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },        
        "gpt-5-5-reasoning:persist": {
          "name": "Copilot (GPT-5.5 Reasoning, persist)",
          "tool_call": true,
          "reasoning": false,
          "attachment": false,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },        
        "gpt-5-6-reasoning:persist": {
          "name": "Copilot (GPT-5.6 Reasoning, persist)",
          "tool_call": true,
          "reasoning": false,
          "attachment": false,
          "limit": {
            "context": 128000,
            "output": 8192
          }
        }
      }
    }
  }
}

{
  "name": "teams-copilot-cli",
  "version": "2.0.3",
  "description": "tcc — a guided 5 Whys root-cause analysis CLI backed by teams-copilot-proxy",
  "type": "module",
  "bin": {
    "tcc": "./dist/cli/index.js",
    "teams-copilot": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "config.example.yaml"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "dev": "tsc --watch",
    "test": "node scripts/run-vitest.mjs run",
    "test:watch": "node scripts/run-vitest.mjs",
    "start": "node dist/cli/index.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}

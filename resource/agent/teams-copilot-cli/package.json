{
  "name": "teams-copilot-cli",
  "version": "2.0.1",
  "description": "Microsoft 365 Copilot CLI — AI Coding assistant via browser automation",
  "type": "module",
  "bin": {
    "tcc": "./dist/cli/index.js",
    "teams-copilot": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "prompts",
    "README.md",
    "OPERATION.md",
    "config.example.yaml"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "dev": "tsc --watch",
    "test": "node scripts/run-vitest.mjs run",
    "test:e2e": "npm run build && playwright test",
    "test:watch": "node scripts/run-vitest.mjs",
    "start": "node dist/cli/index.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0",
    "playwright-core": "^1.40.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
